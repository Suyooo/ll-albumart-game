{
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
	"tailwindConfig": "./tailwind.config.js",
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],
	"tabWidth": 4,
	"useTabs": true,
	"printWidth": 120,
	"trailingComma": "es5",
	"semi": true
}
